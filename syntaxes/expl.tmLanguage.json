{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ExpL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#type_declarations"
    },
    {
      "include": "#decl_declarations"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#types"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "type_declarations": {
      "begin": "\\b(type)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.other.expl"
        }
      },
      "end": "\\b(endtype)\\b",
      "endCaptures": {
        "1": {
          "name": "keyword.other.expl"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "match": "\\b(int|str)\\b",
          "name": "storage.type.expl"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\{)",
          "name": "entity.name.type.class.expl"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s+[a-zA-Z_][a-zA-Z0-9_]*)",
          "name": "storage.type.expl"
        }
      ]
    },
    "decl_declarations": {
      "begin": "\\b(decl)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.other.expl"
        }
      },
      "end": "\\b(enddecl)\\b",
      "endCaptures": {
        "1": {
          "name": "keyword.other.expl"
        }
      },
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "match": "\\b(int|str)\\b",
          "name": "storage.type.expl"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s+[a-zA-Z_][a-zA-Z0-9_]*)",
          "name": "storage.type.expl"
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s*\\()",
          "name": "entity.name.function.expl"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.expl"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.expl"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.expl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.expl",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b[0-9]+\\b",
          "name": "constant.numeric.expl"
        },
        {
          "match": "\\bNULL\\b",
          "name": "constant.language.null.expl"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|then|else|endif|while|do|endwhile|break|continue|begin|end|return)\\b",
          "name": "keyword.control.expl"
        },
        {
          "match": "\\b(read|write|initialize|alloc|free|exposcall)\\b",
          "name": "support.function.expl"
        },
        {
          "match": "\\b(AND|OR|NOT)\\b",
          "name": "keyword.operator.logical.expl"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.expl"
        },
        {
          "match": "\\+|-|\\*|/|%",
          "name": "keyword.operator.arithmetic.expl"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.expl"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(int|str)\\b",
          "name": "storage.type.expl"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b(?!(?:if|then|else|endif|while|do|endwhile|break|continue|begin|end|return|read|write|initialize|alloc|free|exposcall|decl|enddecl|type|endtype|main|AND|OR|NOT|int|str|NULL)\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b|\\s*\\{)",
          "name": "entity.name.type.expl"
        },
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()",
          "name": "entity.name.function.expl"
        }
      ]
    }
  },
  "scopeName": "source.expl"
}
