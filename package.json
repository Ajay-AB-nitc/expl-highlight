{
  "name": "expl-highlight",
  "displayName": "Expl-Highlight",
  "publisher": "AjayAB",
  "icon": "image/icon.png",
  "description": "A simple code highlighter for Expl language",
  "version": "1.0.0",
  "author": {
    "name": "Ajay AB",
    "url": "https://github.com/Ajay-AB-nitc"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ajay-AB-nitc/expl-highlight.git"
  },
  "keywords": [
    "expl",
    "expos",
    "myexpos",
    "xsm",
    "nitc"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "expl",
        "aliases": [
          "ExpL",
          "expl"
        ],
        "extensions": [
          ".expl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "expl",
        "scopeName": "source.expl",
        "path": "./syntaxes/expl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "expl-highlight.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
